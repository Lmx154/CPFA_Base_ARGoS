<?xml version="1.0"?>
<argos-configuration>

  <framework>
    <system threads="0"/>
    <experiment length="180" random_seed="7" ticks_per_second="16"/>
  </framework>

  <controllers>
    <DCPFA_controller id="DCPFA" library="build/source/DCPFA/libDCPFA_controller">
      <actuators>
        <differential_steering implementation="default"/>
        <leds implementation="default" medium="leds"/>
      </actuators>

      <sensors>
        <footbot_proximity implementation="default" show_rays="false"/>
        <positioning implementation="default"/>
        <footbot_motor_ground implementation="rot_z_only"/>
      </sensors>

      <params>
        <settings TargetDistanceTolerance="0.05"
                  TargetAngleTolerance="0.1"
                  FoodDistanceTolerance="0.13"
                  NestDistanceTolerance="0.05"
                  NestAngleTolerance="0.1"
                  SearchStepSize="0.08"
                  RobotForwardSpeed="16.0"
                  RobotRotationSpeed="8.0"
                  DestinationNoiseStdev="0.0"
                  PositionNoiseStdev="0.00"
                  ResultsDirectoryPath="results/"/>
      </params>
    </DCPFA_controller>
  </controllers>

  <loop_functions label="DCPFA_loop_functions" library="build/source/DCPFA/libDCPFA_loop_functions">
    <DCPFA PrintFinalScore="1"
           ProbabilityOfSwitchingToSearching="0.723128706375"
           ProbabilityOfReturningToNest="0.0147598869881"
           UninformedSearchVariation="2.81939731297"
           RateOfInformedSearchDecay="0.205799848158"
           RateOfSiteFidelity="14.1514206414"
           RateOfLayingPheromone="14.7027566005"
           RateOfPheromoneDecay="0.0245057227138"/>

    <settings MaxSimTimeInSeconds="180"
              MaxSimCounter="1"
              VariableFoodPlacement="0"
              OutputData="0"
              DrawDensityRate="4"
              DrawIDs="1"
              DrawTrails="1"
              DrawTargetRays="1"
              FoodDistribution="0"
              FoodItemCount="64"
              PowerlawFoodUnitCount="64"
              NumberOfClusters="2"
              ClusterWidthX="4"
              ClusterWidthY="4"
              FoodRadius="0.05"
              NestRadius="0.137"
              NestElevation="0.001"
              NestPosition="0,0"/>

    <communication EnableDecentralizedSharing="1"
                   CommunicationRadius="2.0"
                   CommunicationPeriodSeconds="0.5"
                   MaxPheromonesPerRobot="64"
                   DebugCommunication="1"/>
  </loop_functions>

  <arena center="0,0,0.5" size="10.0,10.0,1">
    <floor id="floor" source="loop_functions" pixels_per_meter="10"/>

    <box id="wall_north" movable="false" size="10,0.05,0.5">
      <body position="0,5,0" orientation="0,0,0"/>
    </box>
    <box id="wall_south" movable="false" size="10,0.05,0.5">
      <body position="0,-5,0" orientation="0,0,0"/>
    </box>
    <box id="wall_east" movable="false" size="0.05,10,0.5">
      <body position="5,0,0" orientation="0,0,0"/>
    </box>
    <box id="wall_west" movable="false" size="0.05,10,0.5">
      <body position="-5,0,0" orientation="0,0,0"/>
    </box>

    <distribute>
      <position method="grid" center="1.0,1.0,0.0" distances="0.35,0.35,0.0" layout="2,1,1"/>
      <orientation method="constant" values="0.0,0.0,0.0"/>
      <entity quantity="2" max_trials="100">
        <foot-bot id="D0">
          <controller config="DCPFA"/>
        </foot-bot>
      </entity>
    </distribute>

    <distribute>
      <position method="grid" center="1.0,-1.0,0.0" distances="0.35,0.35,0.0" layout="2,1,1"/>
      <orientation method="constant" values="0.0,0.0,0.0"/>
      <entity quantity="2" max_trials="100">
        <foot-bot id="D1">
          <controller config="DCPFA"/>
        </foot-bot>
      </entity>
    </distribute>

    <distribute>
      <position method="grid" center="-1.0,1.0,0.0" distances="0.35,0.35,0.0" layout="2,1,1"/>
      <orientation method="constant" values="0.0,0.0,0.0"/>
      <entity quantity="2" max_trials="100">
        <foot-bot id="D2">
          <controller config="DCPFA"/>
        </foot-bot>
      </entity>
    </distribute>

    <distribute>
      <position method="grid" center="-1.0,-1.0,0.0" distances="0.35,0.35,0.0" layout="2,1,1"/>
      <orientation method="constant" values="0.0,0.0,0.0"/>
      <entity quantity="2" max_trials="100">
        <foot-bot id="D3">
          <controller config="DCPFA"/>
        </foot-bot>
      </entity>
    </distribute>
  </arena>

  <physics_engines>
    <dynamics2d id="dyn2d"/>
  </physics_engines>

  <media>
    <led id="leds"/>
  </media>

  <visualization>
    <qt-opengl>
      <camera>
        <placement idx="0"
                   position="0,-7,7"
                   look_at="0,0,0"
                   lens_focal_length="35"/>
      </camera>
      <user_functions label="DCPFA_qt_user_functions"/>
    </qt-opengl>
  </visualization>
</argos-configuration>
